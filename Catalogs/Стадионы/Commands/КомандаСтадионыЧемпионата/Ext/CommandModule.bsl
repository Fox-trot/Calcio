
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура("Ссылка", СтадионыПолучить(ПараметрКоманды)));
	НаКлиенте.ОбработкаКомандыОткрытьФорму("Справочник.Стадионы.ФормаСписка", ПараметрыФормы, ПараметрыВыполненияКоманды);
КонецПроцедуры

&НаСервере
Функция СтадионыПолучить(Ссылка)
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	Стадионы.Ссылка КАК Ссылка
	                      |ИЗ
	                      |	Справочник.Стадионы КАК Стадионы
	                      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Чемпионаты.Команды КАК ЧемпионатыКоманды
	                      |		ПО Стадионы.Владелец = ЧемпионатыКоманды.Команда
	                      |ГДЕ
	                      |	ЧемпионатыКоманды.Ссылка = &Ссылка
	                      |	И Стадионы.ПометкаУдаления = ЛОЖЬ
	                      |
	                      |ОБЪЕДИНИТЬ
	                      |
	                      |ВЫБРАТЬ РАЗЛИЧНЫЕ
	                      |	Матч.Стадион
	                      |ИЗ
	                      |	Документ.Матч КАК Матч
	                      |ГДЕ
	                      |	Матч.Тур.Владелец = &Ссылка
	                      |	И Матч.Проведен = ИСТИНА
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Ссылка");
	Запрос.УстановитьПараметр("Ссылка",	Ссылка);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
КонецФункции

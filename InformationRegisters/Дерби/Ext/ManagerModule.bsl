
Функция Создать(ДанныеЗаполнения) Экспорт
	Запись = РегистрыСведений.Дерби.СоздатьМенеджерЗаписи();
	Запись.Команда		= ДанныеЗаполнения.Команда;
	Запись.Противник	= ДанныеЗаполнения.Противник;
	Запись.Прочитать();
	Если НЕ Запись.Выбран() Тогда
		ЗаполнитьЗначенияСвойств(Запись, ДанныеЗаполнения);
		Попытка
			Запись.Записать();
		Исключение
			Возврат ОписаниеОшибки();
		КонецПопытки;
	КонецЕсли;
	Возврат "";
КонецФункции

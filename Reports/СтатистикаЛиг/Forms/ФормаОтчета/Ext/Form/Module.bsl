		                              |			КОГДА ТурнирнаяТаблица.КоличествоГолов + Противники.КоличествоГолов >= 3
		                              |				ТОГДА 0
		                              |			ИНАЧЕ 1
		                              |		КОНЕЦ) КАК КоличествоПропущено
		                              |ИЗ
		                              |	РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТурнирнаяТаблица КАК Противники
		                              |		ПО ТурнирнаяТаблица.Регистратор = Противники.Регистратор
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Туры КАК Туры
		                              |		ПО ТурнирнаяТаблица.Тур = Туры.Тур
		                              |ГДЕ
		                              |	ТурнирнаяТаблица.НомерСтроки = 1
		                              |	И Противники.НомерСтроки = 2
		                              |
		                              |СГРУППИРОВАТЬ ПО
		                              |	Туры.Чемпионат,
		                              |	Туры.Точка
		                              |
		                              |УПОРЯДОЧИТЬ ПО
		                              |	Точка";
	ИначеЕсли ТипГрафика = 28 И ЗначениеЗаполнено(Команда) Тогда
		Запрос.Текст = Запрос.Текст + "ВЫБРАТЬ
		                              |	Туры.Чемпионат КАК Чемпионат,
		                              |	Туры.Точка КАК Точка,
		                              |	СУММА(Матч.КоличествоЗрителей) КАК КоличествоЗабито,
		                              |	СУММА(ВЫБОР
		                              |			КОГДА Матч.Стадион.КоличествоЗрителей ЕСТЬ NULL
		                              |				ТОГДА ЕСТЬNULL(Стадионы.КоличествоЗрителей, 0)
		                              |			КОГДА Матч.Стадион.КоличествоЗрителей > Матч.КоличествоЗрителей
		                              |				ТОГДА Матч.Стадион.КоличествоЗрителей - Матч.КоличествоЗрителей
		                              |			ИНАЧЕ 0
		                              |		КОНЕЦ) КАК КоличествоПропущено
		                              |ИЗ
		                              |	Документ.Матч КАК Матч
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
		                              |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Стадионы КАК Стадионы
		                              |			ПО ТурнирнаяТаблица.Команда = Стадионы.Владелец
		                              |		ПО Матч.Ссылка = ТурнирнаяТаблица.Регистратор
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Туры КАК Туры
		                              |		ПО Матч.Тур = Туры.Тур
		                              |ГДЕ
		                              |	ТурнирнаяТаблица.Команда = &Команда
		                              |	И ТурнирнаяТаблица.НомерСтроки = 1
		                              |
		                              |СГРУППИРОВАТЬ ПО
		                              |	Туры.Чемпионат,
		                              |	Туры.Точка
		                              |
		                              |УПОРЯДОЧИТЬ ПО
		                              |	Точка";
	ИначеЕсли ТипГрафика = 28 Тогда
		Запрос.Текст = Запрос.Текст + "ВЫБРАТЬ
		                              |	Туры.Чемпионат КАК Чемпионат,
		                              |	Туры.Точка КАК Точка,
		                              |	СУММА(Матч.КоличествоЗрителей) КАК КоличествоЗабито,
		                              |	СУММА(ВЫБОР
		                              |			КОГДА Матч.Стадион.КоличествоЗрителей ЕСТЬ NULL
		                              |				ТОГДА ЕСТЬNULL(Стадионы.КоличествоЗрителей, 0)
		                              |			КОГДА Матч.Стадион.КоличествоЗрителей > Матч.КоличествоЗрителей
		                              |				ТОГДА Матч.Стадион.КоличествоЗрителей - Матч.КоличествоЗрителей
		                              |			ИНАЧЕ 0
		                              |		КОНЕЦ) КАК КоличествоПропущено
		                              |ИЗ
		                              |	Документ.Матч КАК Матч
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
		                              |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Стадионы КАК Стадионы
		                              |			ПО ТурнирнаяТаблица.Команда = Стадионы.Владелец
		                              |		ПО Матч.Ссылка = ТурнирнаяТаблица.Регистратор
		                              |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Туры КАК Туры
		                              |		ПО Матч.Тур = Туры.Тур
		                              |ГДЕ
		                              |	ТурнирнаяТаблица.НомерСтроки = 1
		                              |
		                              |СГРУППИРОВАТЬ ПО
		                              |	Туры.Чемпионат,
		                              |	Туры.Точка
		                              |
		                              |УПОРЯДОЧИТЬ ПО
		                              |	Точка";
	КонецЕсли;
	Если ЗначениеЗаполнено(Команда) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "11", "21");
	ИначеЕсли ТипГрафика >= 23 Тогда
		//
	ИначеЕсли ТипГрафика >= 12 Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Количество УБЫВ", "Количество");
	КонецЕсли;
	Запрос.УстановитьПараметр("Лига",			Лига);
	Запрос.УстановитьПараметр("Команда",		Команда);
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
КонецФункции

&НаСервере
Процедура ГрафикОбновить()
	Отчет.Данные.Очистить();
	График.Очистить();
	Если НЕ ЗначениеЗаполнено(Отчет.Лига) Тогда Возврат; КонецЕсли;
	
	График.ВидПодписей	= ВидПодписейКДиаграмме.Нет;
	График.ОбластьЗаголовка.Текст = ?(Разделить("18 20 23 24").Найти(ФорматЧГ(ТипГрафика)) = Неопределено, "", "Меньше - лучше");
	График.ОбластьЛегенды.Расположение = ?(ЗначениеЗаполнено(Отчет.Команда) И СтрНайти("0,2,3,4,9,10,11", ТипГрафика) > 0, РасположениеЛегендыДиаграммы.Нет, РасположениеЛегендыДиаграммы.Авто);
	Если ТипГрафика >= 25 Тогда
		График.ТипДиаграммы	= ТипДиаграммы.ГистограммаСНакоплением;
		График.ОбластьПостроения.ШкалаЗначений.ШагШкалы = ?(ТипГрафика = 25, 50, ?(ТипГрафика = 26 Или ТипГрафика = 27, 20, 0));
		График.ВидПодписей	= ВидПодписейКДиаграмме.Процент;
	ИначеЕсли ЗначениеЗаполнено(Отчет.Команда)
	И ТипГрафика = 7
	Тогда
		График.ТипДиаграммы	= ТипДиаграммы.ГистограммаСНакоплением;
		График.ОбластьПостроения.ШкалаЗначений.ШагШкалы = 10;
		График.ВидПодписей	= ВидПодписейКДиаграмме.Процент;
	Иначе
		График.ТипДиаграммы	= ТипДиаграммы.Гистограмма;
		График.ОбластьПостроения.ШкалаЗначений.ШагШкалы = ?(СтрНайти("0,7,8,11,12,19,20,23", ТипГрафика) > 0, 10, 2);
	КонецЕсли;
	
	Чемпионаты	= ДанныеПолучить(Отчет.Лига, ТипГрафика, Отчет.Команда);
	Максимально	= 0;
	Если Чемпионаты.Количество() = 0 Тогда
		Возврат;
	ИначеЕсли ТипГрафика >= 25 Тогда
		Если ТипГрафика = 25 Тогда
			Хозяева	= График.УстановитьСерию("Хозяева");
			Гости	= График.УстановитьСерию("Гости");
		ИначеЕсли ТипГрафика = 26 И ЗначениеЗаполнено(Отчет.Команда) Тогда
			СерверныйФункции.СерииЗаполнить(График);
		ИначеЕсли ТипГрафика = 26 Тогда
			Хозяева	= График.УстановитьСерию("Ничья");
			Гости	= График.УстановитьСерию("Победа");
		ИначеЕсли ТипГрафика = 27 Тогда
			Хозяева	= График.УстановитьСерию("ТБ 2.5");
			Гости	= График.УстановитьСерию("ТМ 2.5");
		Иначе
			Хозяева	= График.УстановитьСерию("Зрители");
			Гости	= График.УстановитьСерию("Пусто");
		КонецЕсли;
		Пока Чемпионаты.Следующий() Цикл
			Точка = График.УстановитьТочку(ФорматЧГ(Чемпионаты.Точка));
			Точка.Расшифровка = Чемпионаты.Чемпионат;
			Если ТипГрафика = 26 И ЗначениеЗаполнено(Отчет.Команда) Тогда
				График.УстановитьЗначение(Точка, 0, Чемпионаты.КоличествоПропущено);
				График.УстановитьЗначение(Точка, 1, Чемпионаты.Количество);
				График.УстановитьЗначение(Точка, 2, Чемпионаты.КоличествоЗабито);
				
				Максимально = Макс(Максимально, Чемпионаты.КоличествоЗабито + Чемпионаты.КоличествоПропущено + Чемпионаты.Количество);
			Иначе
				График.УстановитьЗначение(Точка, Хозяева, Чемпионаты.КоличествоЗабито);
				График.УстановитьЗначение(Точка, Гости, Чемпионаты.КоличествоПропущено);
				
				Максимально = Макс(Максимально, Чемпионаты.КоличествоЗабито + Чемпионаты.КоличествоПропущено);
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ЗначениеЗаполнено(Отчет.Команда)
	И ТипГрафика = 7
	Тогда
		СерверныйФункции.СерииЗаполнить(График, Истина);
		Пока Чемпионаты.Следующий() Цикл
			Точка = График.УстановитьТочку(ФорматЧГ(Чемпионаты.Точка));
			Точка.Расшифровка = Чемпионаты.Чемпионат;
			График.УстановитьЗначение(Точка, 0, Чемпионаты.КоличествоЗабито);
			График.УстановитьЗначение(Точка, 1, Чемпионаты.КоличествоПропущено);
			
			Максимально = Макс(Максимально, Чемпионаты.КоличествоЗабито + Чемпионаты.КоличествоПропущено);
		КонецЦикла;
		
	Иначе
		Значения	= Новый Массив;
		Точки		= Новый Соответствие;
		Серии		= Новый Соответствие;
		
		Если ЗначениеЗаполнено(Отчет.Команда) Тогда
			ЗаполнитьЗначенияСвойств(Отчет.Данные.Добавить(), Новый Структура("Серия", Отчет.Команда));
			Пока Чемпионаты.Следующий() Цикл
				Точка = График.УстановитьТочку(ФорматЧГ(Чемпионаты.Точка));
				Точка.Расшифровка = Чемпионаты.Чемпионат;
				
				Точки.Вставить(Чемпионаты.Чемпионат, Точка);
			КонецЦикла;
		Иначе
			ЗначениеК	= ?(ТипГрафика <= 11 Или ТипГрафика = 23 Или ТипГрафика = 24, 2, 1);
			Пока Чемпионаты.Следующий() Цикл
				Значения.Очистить();
				Количество	= 0;
				
				Выборка	= Чемпионаты.Выбрать();
				Пока Выборка.Следующий() И Значения.Количество() < ЗначениеК Или Выборка.Количество = Количество Цикл
					Значения.Добавить(Выборка.Количество);
					Количество = Выборка.Количество;
					
					Если Отчет.Данные.НайтиСтроки(Новый Структура("Серия", Выборка.Серия)).Количество() = 0 Тогда
						ЗаполнитьЗначенияСвойств(Отчет.Данные.Добавить(), Выборка);
					КонецЕсли;
					Точка	= Точки.Получить(Выборка.Чемпионат);
					Если Точка = Неопределено Тогда
						Точка = График.УстановитьТочку(ФорматЧГ(Выборка.Точка));
						Точка.Расшифровка = Выборка.Чемпионат;
						
						Точки.Вставить(Выборка.Чемпионат, Точка);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			Отчет.Данные.Сортировать("Серия");
		КонецЕсли;
		Чемпионаты.Сбросить();
		Для Каждого ТекСтрока Из Отчет.Данные Цикл
			Серия = График.УстановитьСерию(ТекСтрока.Серия);
			Цвет	= Цвет(ТекСтрока.Серия);
			Если ЗначениеЗаполнено(Цвет) Тогда
				Серия.Цвет				= Цвет;
				Серия.ПриоритетЦвета	= Истина;
			КонецЕсли;
			Серия.Расшифровка	= ТекСтрока.Серия;
			
			Серии.Вставить(ТекСтрока.Серия, Серия);
		КонецЦикла;
		
		Пока Чемпионаты.Следующий() Цикл
			Количество	= 0;
			Выборка	= Чемпионаты.Выбрать();
			Пока Выборка.Следующий() Цикл
				Количество	= Количество + 1;
				Серия	= Серии.Получить(Выборка.Серия);
				Если Серия = Неопределено Тогда Продолжить; КонецЕсли;
				
				График.УстановитьЗначение(Точки.Получить(Выборка.Чемпионат), Серия, ?(ТипГрафика = 24, Количество, Выборка.Количество));
				
				Максимально = Макс(Максимально, ?(ТипГрафика = 24, Количество, Выборка.Количество));
				
				Если ЗначениеЗаполнено(Отчет.Команда) Тогда Прервать; КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	График.ОсьЗначений.МаксимальноеЗначение = ?(Максимально <= 40, Максимально, ?(ТипГрафика = 28, Окр(Максимально + 500, -3), Окр(Максимально + 5, -1)));
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда=Неопределено)
	Если ПроверитьЗаполнение() Тогда
		ГрафикОбновить();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ТипГрафикаЗагрузить()
	Если ЗначениеЗаполнено(Отчет.Команда) Тогда
		Если Элементы.ТипГрафика.СписокВыбора.НайтиПоЗначению(23) <> Неопределено
		Или Элементы.ТипГрафика.СписокВыбора.Количество() = 0
		Тогда
			Элементы.ТипГрафика.СписокВыбора.Очистить();
			Элементы.ТипГрафика.СписокВыбора.Добавить(0, "Количество очков");
			Элементы.ТипГрафика.СписокВыбора.Добавить(2, "Количество 'верховых' побед");
			Элементы.ТипГрафика.СписокВыбора.Добавить(3, "Количество 'низовых' побед");
			Элементы.ТипГрафика.СписокВыбора.Добавить(4, "Количество 'сухих' побед");
			
			Элементы.ТипГрафика.СписокВыбора.Добавить(7, "Количество голов забито | пропущено");
			
			Элементы.ТипГрафика.СписокВыбора.Добавить(9, "Количество 'верховых' матчей");
			Элементы.ТипГрафика.СписокВыбора.Добавить(10, "Количество 'сухих' матчей");
			Элементы.ТипГрафика.СписокВыбора.Добавить(11, "Разница голов");
			
			Элементы.ТипГрафика.СписокВыбора.Добавить(24, "Место в турнирной таблице");
			Элементы.ТипГрафика.СписокВыбора.Добавить(25, "Количество голов дома | выезд");
			Элементы.ТипГрафика.СписокВыбора.Добавить(26, "Количество побед | ничьих | проигрышей");
			Элементы.ТипГрафика.СписокВыбора.Добавить(27, "Количество 'верховых | низовых' матчей");
			Элементы.ТипГрафика.СписокВыбора.Добавить(28, "Посещаемость");
		КонецЕсли;
	ИначеЕсли Элементы.ТипГрафика.СписокВыбора.НайтиПоЗначению(23) = Неопределено Тогда
		Элементы.ТипГрафика.СписокВыбора.Очистить();
		Элементы.ТипГрафика.СписокВыбора.Добавить(0, "Максимальное количество очков");
		Элементы.ТипГрафика.СписокВыбора.Добавить(1, "Максимальное количество побед");
		Элементы.ТипГрафика.СписокВыбора.Добавить(2, "Максимальное количество 'верховых' побед");
		Элементы.ТипГрафика.СписокВыбора.Добавить(3, "Максимальное количество 'низовых' побед");
		Элементы.ТипГрафика.СписокВыбора.Добавить(4, "Максимальное количество 'сухих' побед");
		Элементы.ТипГрафика.СписокВыбора.Добавить(5, "Максимальное количество ничьих");
		Элементы.ТипГрафика.СписокВыбора.Добавить(6, "Максимальное количество проигрышей");
		Элементы.ТипГрафика.СписокВыбора.Добавить(7, "Максимальное количество голов (забито)");
		Элементы.ТипГрафика.СписокВыбора.Добавить(8, "Максимальное количество голов (пропущено)");
		Элементы.ТипГрафика.СписокВыбора.Добавить(9, "Максимальное количество 'верховых' матчей");

&НаСервере
Процедура ГрафикОбновить()
	График.Очистить();
	Если ТипГрафика >= 25 Тогда
		График.ТипДиаграммы	= ТипДиаграммы.ГистограммаСНакоплением;
		График.ОбластьПостроения.ШкалаЗначений.ШагШкалы = ?(ТипГрафика = 25, 100, 0);
		График.ОбластьЗаголовка.Текст = "";
		График.ВидПодписей	= ВидПодписейКДиаграмме.Процент;
	Иначе
		График.ТипДиаграммы	= ТипДиаграммы.Гистограмма;
		График.ОбластьПостроения.ШкалаЗначений.ШагШкалы = ?(СтрНайти("0,7,8,11,12,19,20,23", ТипГрафика) > 0, 10, 2);
		График.ОбластьЗаголовка.Текст = ?(СтрНайти("18,20,23,24", ТипГрафика) = 0, "", "Меньше - лучше");
		График.ВидПодписей	= ВидПодписейКДиаграмме.Нет;
	КонецЕсли;
	
	Чемпионаты	= ДанныеПолучить(Отчет.Лига, ТипГрафика);
	Если ТипГрафика >= 25 Тогда
		Если ТипГрафика = 25 Тогда
			Хозяева	= График.УстановитьСерию("Хозяева");
			Гости	= График.УстановитьСерию("Гости");
		ИначеЕсли ТипГрафика = 26 Тогда
			Хозяева	= График.УстановитьСерию("Ничья");
			Гости	= График.УстановитьСерию("Победа");
		Иначе	//Если ТипГрафика = 27 Тогда
			Хозяева	= График.УстановитьСерию("ТБ 2.5");
			Гости	= График.УстановитьСерию("ТМ 2.5");
		КонецЕсли;
		Пока Чемпионаты.Следующий() Цикл
			Точка = График.УстановитьТочку(ФорматЧГ(Чемпионаты.Точка));
			Точка.Расшифровка = Чемпионаты.Чемпионат;
			График.УстановитьЗначение(Точка, Хозяева, Чемпионаты.КоличествоЗабито);
			График.УстановитьЗначение(Точка, Гости, Чемпионаты.КоличествоПропущено);
		КонецЦикла;
	Иначе
		Максимально	= 0;
		Значения	= Новый Массив;
		ЗначениеК	= ?(ТипГрафика <= 11 Или ТипГрафика = 23, 2, 1);
		Количество	= 0;
		Точки		= Новый Соответствие;
		Серии		= Новый Соответствие;
		
		Пока Чемпионаты.Следующий() Цикл
			Значения.Очистить();
			
			Выборка	= Чемпионаты.Выбрать();
			Пока Выборка.Следующий() И Значения.Количество() < ЗначениеК Или Выборка.Количество = Количество Цикл
				Значения.Добавить(Выборка.Количество);
				
				Если Отчет.Данные.НайтиСтроки(Новый Структура("Серия", Выборка.Серия)).Количество() = 0 Тогда
					ЗаполнитьЗначенияСвойств(Отчет.Данные.Добавить(), Выборка);
				КонецЕсли;
				Количество = Выборка.Количество;
			КонецЦикла;
		КонецЦикла;
		Чемпионаты.Сбросить();
		Отчет.Данные.Сортировать("Серия");
		Для Каждого ТекСтрока Из Отчет.Данные Цикл
			Серия = График.УстановитьСерию(ТекСтрока.Серия);
			Цвет	= Цвет(ТекСтрока.Серия);
			Если ЗначениеЗаполнено(Цвет) Тогда
				Серия.Цвет				= Цвет;
				Серия.ПриоритетЦвета	= Истина;
			КонецЕсли;
			Серия.Расшифровка	= ТекСтрока.Серия;
			
			Серии.Вставить(ТекСтрока.Серия, Серия);
		КонецЦикла;
		
		Пока Чемпионаты.Следующий() Цикл
			Количество	= 0;
			Выборка	= Чемпионаты.Выбрать();
			Пока Выборка.Следующий() Цикл
				Количество	= Количество + 1;
				Серия	= Серии.Получить(Выборка.Серия);
				Если Серия = Неопределено Тогда Продолжить; КонецЕсли;
				
				Точка	= Точки.Получить(Выборка.Чемпионат);
				Если Точка = Неопределено Тогда
					Точка = График.УстановитьТочку(ФорматЧГ(Выборка.Точка));
					Точка.Расшифровка = Выборка.Чемпионат;
					
					Точки.Вставить(Выборка.Чемпионат, Точка);
				КонецЕсли;
				График.УстановитьЗначение(Точка, Серия, ?(ТипГрафика = 24, Количество, Выборка.Количество));
				
				Максимально = Макс(Максимально, ?(ТипГрафика = 24, Количество, Выборка.Количество));
			КонецЦикла;
		КонецЦикла;
		График.ОсьЗначений.МаксимальноеЗначение = Окр(Максимально + 5, -1);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда=Неопределено)
	Если ПроверитьЗаполнение() Тогда
		ГрафикОбновить();
	КонецЕсли;
КонецПроцедуры


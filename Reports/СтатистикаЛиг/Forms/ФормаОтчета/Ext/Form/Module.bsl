&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Лига") Тогда
		Отчет.Лига	= Параметры.Лига;
		ОбщегоНазначения.ЗаголовокСкрыть(ЭтаФорма, Элементы.Лига);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если НЕ ЗначениеЗаполнено(Отчет.Лига) Тогда
		Отчет.Лига = МояЛига();
	КонецЕсли;
	Если ЗначениеЗаполнено(Отчет.Лига) Тогда
		КомандыЗагрузить();
	КонецЕсли;
	ТипГрафикаЗагрузить();
	Сформировать();
КонецПроцедуры

&НаКлиенте
Процедура ГрафикОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
	Если ТипЗнч(Расшифровка) = Тип("СправочникСсылка.Чемпионаты") Тогда
		СтандартнаяОбработка = Ложь;
		
		Форма = ПолучитьФорму("Отчет.ТурнирнаяТаблица.Форма");
		Форма.АвтоматическоеСохранениеДанныхВНастройках = АвтоматическоеСохранениеДанныхФормыВНастройках.НеИспользовать;
		Форма.Отчет.Чемпионат = Расшифровка;
		Если Форма.Открыта() Тогда
			Форма.КомандаСформировать();
		КонецЕсли;
		Форма.Открыть();
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция МояЛига()
	Возврат СерверныйФункции.Лига(СерверныйФункции.ЧемпионатПолучитьПоследнее());
КонецФункции

&НаКлиенте
Процедура КомандаОчистка(Элемент, СтандартнаяОбработка)
	ТипГрафикаЗагрузить();
	ГрафикОбновить();
КонецПроцедуры

&НаСервереБезКонтекста
Функция КомандыПолучить(Лига)
	Запрос	= Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 11
	      	               |	ТурнирнаяТаблица.Тур.Владелец КАК Чемпионат,
	      	               |	ГОД(ТурнирнаяТаблица.Тур.Владелец.ДатаОкончания) КАК Точка
	      	               |ПОМЕСТИТЬ Чемпионаты
	      	               |ИЗ
	      	               |	РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
	      	               |ГДЕ
	      	               |	ТурнирнаяТаблица.Тур.Владелец.Владелец = &Лига
	      	               |
	      	               |СГРУППИРОВАТЬ ПО
	      	               |	ТурнирнаяТаблица.Тур.Владелец,
	      	               |	ГОД(ТурнирнаяТаблица.Тур.Владелец.ДатаОкончания)
	      	               |
	      	               |ИМЕЮЩИЕ
	      	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТурнирнаяТаблица.Регистратор) >= 0.62 * КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТурнирнаяТаблица.Команда) * КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТурнирнаяТаблица.Команда)
	      	               |
	      	               |УПОРЯДОЧИТЬ ПО
	      	               |	МАКСИМУМ(ТурнирнаяТаблица.Период) УБЫВ
	      	               |;
	      	               |
	      	               |////////////////////////////////////////////////////////////////////////////////
	      	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	      	               |	ТурнирнаяТаблица.Тур КАК Тур,
	      	               |	Туры.Владелец КАК Чемпионат
	      	               |ПОМЕСТИТЬ Туры
	      	               |ИЗ
	      	               |	РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
	      	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Туры КАК Туры
	      	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Чемпионаты КАК Чемпионаты
	      	               |			ПО Туры.Владелец = Чемпионаты.Чемпионат
	      	               |		ПО ТурнирнаяТаблица.Тур = Туры.Ссылка
	      	               |ГДЕ
	      	               |	Туры.ОлимпийскаяСистема = ЛОЖЬ
	      	               |;
	      	               |
	      	               |////////////////////////////////////////////////////////////////////////////////
	      	               |ВЫБРАТЬ
	      	               |	ТурнирнаяТаблица.Команда КАК Команда
	      	               |ИЗ
	      	               |	РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
	      	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Туры КАК Туры
	      	               |		ПО ТурнирнаяТаблица.Тур = Туры.Тур
	      	               |
	      	               |СГРУППИРОВАТЬ ПО
	      	               |	ТурнирнаяТаблица.Команда
	      	               |
	      	               |ИМЕЮЩИЕ
	      	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Туры.Чемпионат) > 3
	      	               |
	      	               |УПОРЯДОЧИТЬ ПО
	      	               |	Команда
	      	               |АВТОУПОРЯДОЧИВАНИЕ");
	Запрос.УстановитьПараметр("Лига",			Лига);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
КонецФункции

&НаКлиенте
Процедура КомандаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка	= Ложь;
	Если ЗначениеЗаполнено(Отчет.Лига) Тогда
		КомандыЗагрузить();
		ОткрытьФорму("Справочник.Команды.ФормаВыбора", Новый Структура("Отбор", Новый Структура("Ссылка", КомандыПолучить(Отчет.Лига))), Элемент);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КомандыЗагрузить()
	Если Клубы.Количество() = 0 Тогда
		Клубы.ЗагрузитьЗначения(КомандыПолучить(Отчет.Лига));
		Элементы.Команда.СписокВыбора.ЗагрузитьЗначения(Клубы.ВыгрузитьЗначения());
		ПодключитьОбработчикОжидания("КартинкиЗагрузить", 0.1, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЛигаПриИзменении(Элемент)
	Отчет.Команда = Неопределено;
	Клубы.Очистить();
	КомандыЗагрузить();
	ГрафикОбновить();
КонецПроцедуры

&НаКлиенте
Процедура КартинкиЗагрузить() Экспорт
	ОбщегоНазначения.КартинкиЗагрузить(Элементы.Команда.СписокВыбора, Кеш);
КонецПроцедуры

&НаКлиенте
Процедура КомандаПриИзменении(Элемент)
	ТипГрафикаЗагрузить();
	ГрафикОбновить();
КонецПроцедуры

&НаКлиенте
Процедура ТипГрафикаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	ПодключитьОбработчикОжидания("ТипГрафикаЗагрузитьАсинх", 0.1, Истина);
КонецПроцедуры

&НаКлиенте
Процедура ТипГрафикаЗагрузитьАсинх() Экспорт
	ТипГрафикаЗагрузить();
КонецПроцедуры

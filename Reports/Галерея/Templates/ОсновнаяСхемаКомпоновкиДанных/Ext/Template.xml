		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ ПЕРВЫЕ 9999
	Ссылки.Ссылка КАК Ссылка,
	Ссылки.Порядок КАК Порядок,
	Ссылки.Дата КАК Дата
ПОМЕСТИТЬ Ссылки
ИЗ
	(ВЫБРАТЬ
		ПеремещенияИгроков.Игрок КАК Ссылка,
		МИНИМУМ(ВЫБОР
				КОГДА ПеремещенияИгроков.Команда = СрезПоследних.Команда
					ТОГДА 1
				КОГДА ПеремещенияИгроков.Команда = МатчСоставыКоманд.Команда
					ТОГДА 2
				ИНАЧЕ 3
			КОНЕЦ) КАК Порядок,
		МАКСИМУМ(ВЫБОР
				КОГДА ПеремещенияИгроков.Команда = МатчСоставыКоманд.Команда
					ТОГДА МатчСоставыКоманд.Ссылка.Дата
				КОГДА ПеремещенияИгроков.Команда = СрезПоследних.Команда
					ТОГДА НАЧАЛОПЕРИОДА(СрезПоследних.Период, ГОД)
				ИНАЧЕ ПеремещенияИгроков.Игрок.ДатаРождения
			КОНЕЦ) КАК Дата
	ИЗ
		РегистрСведений.ПеремещенияИгроков КАК ПеремещенияИгроков
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ПеремещенияИгроков.Игрок КАК Игрок,
				ПеремещенияИгроков.Команда КАК Команда,
				ПеремещенияИгроков.Период КАК Период
			ИЗ
				РегистрСведений.ПеремещенияИгроков.СрезПоследних(, РАЗМЕРХРАНИМЫХДАННЫХ(Игрок.Изображение) &gt;= 64) КАК ПеремещенияИгроков) КАК СрезПоследних
			ПО ПеремещенияИгроков.Игрок = СрезПоследних.Игрок
				И ПеремещенияИгроков.Команда = СрезПоследних.Команда
			ЛЕВОЕ СОЕДИНЕНИЕ Документ.Матч.СоставыКоманд КАК МатчСоставыКоманд
			ПО ПеремещенияИгроков.Игрок = МатчСоставыКоманд.Игрок
				И ПеремещенияИгроков.Команда = МатчСоставыКоманд.Команда
				И (МатчСоставыКоманд.Ссылка.Проведен = ИСТИНА)
	ГДЕ
		ПеремещенияИгроков.Команда = &amp;Команда
		И РАЗМЕРХРАНИМЫХДАННЫХ(ПеремещенияИгроков.Игрок.Изображение) &gt;= 64
	
	СГРУППИРОВАТЬ ПО
		ПеремещенияИгроков.Игрок
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ТурнирнаяТаблица.Регистратор,
		7,
		ТурнирнаяТаблица.Период
	ИЗ
		РегистрНакопления.ТурнирнаяТаблица КАК ТурнирнаяТаблица
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Матч КАК Матч
			ПО ТурнирнаяТаблица.Регистратор = Матч.Ссылка
	ГДЕ
		ТурнирнаяТаблица.Команда = &amp;Команда
		И РАЗМЕРХРАНИМЫХДАННЫХ(Матч.Изображение) &gt;= 64
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		Команды.Ссылка,
		99,
		ДАТАВРЕМЯ(1900, 1, 1)
	ИЗ
		Справочник.Команды КАК Команды
	ГДЕ
		Команды.Ссылка = &amp;Команда
		И РАЗМЕРХРАНИМЫХДАННЫХ(Команды.Изображение) &gt;= 64) КАК Ссылки

УПОРЯДОЧИТЬ ПО
	Порядок,
	Дата УБЫВ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Ссылки.Ссылка КАК Ссылка,
	Ссылки.Порядок КАК Порядок,
	Ссылки.Дата КАК Дата,
	АВТОНОМЕРЗАПИСИ() КАК Номер
ПОМЕСТИТЬ Данные
ИЗ
	Ссылки КАК Ссылки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Данные.Ссылка КАК Ссылка,
	Данные.Ссылка.Изображение КАК Изображение,
	Данные.Порядок + ЕСТЬNULL(ВложенныйЗапрос.Порядок, 0) КАК Порядок,
	ВложенныйЗапрос.Ссылка КАК Ссылка1,
	ВложенныйЗапрос.Ссылка.Изображение КАК Изображение1,
	Данные.Дата КАК Дата
ИЗ
	Данные КАК Данные
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			Данные.Номер - 1 КАК Номер,
			Данные.Порядок КАК Порядок,
			Данные.Ссылка КАК Ссылка
		ИЗ
			Данные КАК Данные
		ГДЕ
			Данные.Номер / 2 = ЦЕЛ(Данные.Номер / 2)
			И Данные.Порядок &lt; 99) КАК ВложенныйЗапрос
		ПО Данные.Номер = ВложенныйЗапрос.Номер
ГДЕ
	ВЫБОР
			КОГДА (Данные.Номер + 1) / 2 = ЦЕЛ((Данные.Номер + 1) / 2)
				ТОГДА ИСТИНА
			ИНАЧЕ Данные.Порядок = 99
		КОНЕЦ</query>

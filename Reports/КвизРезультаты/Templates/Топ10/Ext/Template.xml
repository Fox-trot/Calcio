		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Квиз.Уровень КАК Уровень,
	Квиз.КоличествоВопросов КАК КоличествоВопросов,
	Квиз.Период КАК Период,
	Квиз.Время КАК Время
ИЗ
	(ВЫБРАТЬ ПЕРВЫЕ 10
		Квиз.Уровень КАК Уровень,
		Квиз.КоличествоВопросов КАК КоличествоВопросов,
		Квиз.Период КАК Период,
		Квиз.Сессия КАК Сессия,
		СУММА(КвизРезультаты.Время) КАК Время
	ИЗ
		РегистрСведений.КвизРезультаты КАК КвизРезультаты
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Квиз КАК Квиз
			ПО КвизРезультаты.Период = Квиз.Период
				И КвизРезультаты.Сессия = Квиз.Сессия
	ГДЕ
		ВЫБОР
				КОГДА &amp;Уровень = -1
					ТОГДА ИСТИНА
				ИНАЧЕ Квиз.Уровень = &amp;Уровень
			КОНЕЦ
		И ВЫБОР
				КОГДА &amp;КоличествоВопросов = 0
					ТОГДА ИСТИНА
				ИНАЧЕ Квиз.КоличествоВопросов = &amp;КоличествоВопросов
			КОНЕЦ
		И КвизРезультаты.Время &gt; 0
	
	СГРУППИРОВАТЬ ПО
		Квиз.Период,
		Квиз.Уровень,
		Квиз.КоличествоВопросов,
		Квиз.Сессия
	
	ИМЕЮЩИЕ
		КОЛИЧЕСТВО(КвизРезультаты.Период) = Квиз.КоличествоВопросов
	
	УПОРЯДОЧИТЬ ПО
		Время,
		Период УБЫВ) КАК Квиз</query>

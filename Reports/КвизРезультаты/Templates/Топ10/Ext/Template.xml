		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	Квиз.Уровень КАК Уровень,
	Квиз.КоличествоВопросов КАК КоличествоВопросов
ИЗ
	РегистрСведений.Квиз КАК Квиз
ГДЕ
	ВЫБОР
			КОГДА &amp;Уровень = -1
				ТОГДА ИСТИНА
			ИНАЧЕ Квиз.Уровень = &amp;Уровень
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;КоличествоВопросов = 0
				ТОГДА ИСТИНА
			ИНАЧЕ Квиз.КоличествоВопросов = &amp;КоличествоВопросов
		КОНЕЦ</query>

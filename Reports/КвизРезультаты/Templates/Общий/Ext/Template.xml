		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	НАЧАЛОПЕРИОДА(Квиз.Период, ДЕНЬ) КАК Период,
	Квиз.Сессия КАК Сессия,
	Квиз.Уровень КАК Уровень,
	Квиз.КоличествоВопросов КАК КоличествоВопросов,
	СУММА(ВЫБОР
			КОГДА КвизРезультаты.Время &lt;= 0
				ТОГДА 0
			ИНАЧЕ 1
		КОНЕЦ) КАК ПравильныхОтветов,
	СУММА(ВЫБОР
			КОГДА КвизРезультаты.Время &gt;= 0
				ТОГДА КвизРезультаты.Время
			ИНАЧЕ -КвизРезультаты.Время
		КОНЕЦ) КАК Время
ИЗ
	РегистрСведений.Квиз КАК Квиз
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КвизРезультаты КАК КвизРезультаты
		ПО Квиз.Период = КвизРезультаты.Период
			И Квиз.Сессия = КвизРезультаты.Сессия
ГДЕ
	ВЫБОР
			КОГДА &amp;Уровень = -1
				ТОГДА ИСТИНА
			ИНАЧЕ Квиз.Уровень = &amp;Уровень
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;КоличествоВопросов = 0
				ТОГДА ИСТИНА
			ИНАЧЕ Квиз.КоличествоВопросов = &amp;КоличествоВопросов
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	Квиз.Уровень,
	Квиз.КоличествоВопросов,
	Квиз.Период,
	Квиз.Сессия</query>
